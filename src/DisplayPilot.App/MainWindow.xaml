<Window
    x:Class="DisplayPilot.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:DisplayPilot.App"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="DisplayPilot">

    <Grid
        x:Name="RootGrid"
        Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
        Loaded="RootGrid_Loaded">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Padding="24,20,24,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="4">
                <TextBlock
                    Style="{StaticResource TitleTextBlockStyle}"
                    Text="DisplayPilot" />
                <TextBlock
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="Active display-path verification" />
            </StackPanel>

            <StackPanel
                Grid.Column="1"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="8">
                <Button
                    x:Name="RescanButton"
                    Click="RescanButton_Click"
                    Content="Rescan displays" />
                <Button
                    x:Name="ProbeDdcButton"
                    Click="ProbeDdcButton_Click"
                    Content="Read brightness (VCP 0x10)"
                    IsEnabled="False" />
            </StackPanel>
        </Grid>

        <InfoBar
            Grid.Row="1"
            Margin="24,0,24,12"
            IsClosable="False"
            IsOpen="True"
            Message="Startup reads display topology only. The brightness button explicitly sends one read-only VCP 0x10 query per physical monitor; no monitor setting is changed."
            Severity="Informational"
            Title="Read-only hardware check" />

        <Grid Grid.Row="2" Padding="24,0,24,12">
            <ListView
                x:Name="MonitorList"
                HorizontalContentAlignment="Stretch"
                SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="local:MonitorCardViewModel">
                        <Border
                            Margin="0,0,0,10"
                            Padding="16"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                            <StackPanel Spacing="6">
                                <TextBlock
                                    Style="{StaticResource SubtitleTextBlockStyle}"
                                    Text="{x:Bind FriendlyName, Mode=OneWay}" />
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        FontWeight="SemiBold"
                                        Text="Windows name" />
                                    <TextBlock
                                        Grid.Column="1"
                                        FontFamily="Consolas"
                                        Text="{x:Bind GdiDeviceName, Mode=OneWay}" />
                                </Grid>
                                <TextBlock
                                    FontWeight="SemiBold"
                                    Text="Stable device path" />
                                <TextBox
                                    Padding="0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    FontFamily="Consolas"
                                    IsReadOnly="True"
                                    Text="{x:Bind DevicePath, Mode=OneWay}"
                                    TextWrapping="Wrap" />
                                <TextBlock
                                    Margin="0,6,0,0"
                                    FontWeight="SemiBold"
                                    Text="{x:Bind DdcStatus, Mode=OneWay}" />
                                <TextBlock
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="{x:Bind DdcDetails, Mode=OneWay}"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <StackPanel
                x:Name="EmptyState"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="8"
                Visibility="Collapsed">
                <FontIcon
                    HorizontalAlignment="Center"
                    FontSize="36"
                    Glyph="&#xE7F4;" />
                <TextBlock
                    Style="{StaticResource SubtitleTextBlockStyle}"
                    Text="No active display paths were returned." />
                <TextBlock
                    HorizontalAlignment="Center"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="Try rescanning after the Windows desktop has finished loading." />
            </StackPanel>
        </Grid>

        <Border
            Grid.Row="3"
            Padding="24,12,24,20"
            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="3">
                    <TextBlock
                        x:Name="StatusText"
                        FontWeight="SemiBold"
                        Text="Waiting to scan..." />
                    <TextBlock
                        x:Name="SystemText"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>

                <Button
                    x:Name="CopyReportButton"
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Click="CopyReportButton_Click"
                    Content="Copy diagnostic report"
                    IsEnabled="False" />
            </Grid>
        </Border>
    </Grid>
</Window>
