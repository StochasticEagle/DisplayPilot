<Window
    x:Class="DisplayPilot.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:DisplayPilot.App"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="DisplayPilot"
    mc:Ignorable="d">

    <Grid
        x:Name="RootGrid"
        Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
        Loaded="RootGrid_Loaded">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header Section -->
        <Grid Grid.Row="0" Padding="24,20,24,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="480" />
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="4">
                <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="DisplayPilot" />
                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Windows theme and display verification" />
            </StackPanel>

            <StackPanel
                Grid.Column="1"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="8">
                <Button
                    x:Name="RescanButton"
                    Click="RescanButton_Click"
                    Content="Rescan displays" />
                <Button
                    x:Name="ProbeDdcButton"
                    Click="ProbeDdcButton_Click"
                    Content="Read brightness (DDC + WMI)"
                    IsEnabled="False" />
            </StackPanel>
        </Grid>

        <!-- Main Workspace (Two-Column Layout) -->
        <Grid Grid.Row="1" Padding="24,0,24,12" ColumnSpacing="24">
            <Grid.ColumnDefinitions>
                <!-- Left Column: Main Display List Content -->
                <ColumnDefinition Width="*" />
                <!-- Right Column: Settings, Schedules & Actions -->
                <ColumnDefinition Width="480" />
            </Grid.ColumnDefinitions>

            <!-- Main Display List Content (Left Column) -->
            <Grid Grid.Column="0">
                <ListView
                    x:Name="MonitorList"
                    HorizontalContentAlignment="Stretch"
                    SelectionChanged="MonitorList_SelectionChanged"
                    SelectionMode="Single">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:MonitorCardViewModel">
                            <Border
                                Margin="0,0,0,10"
                                Padding="16"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                                <StackPanel Spacing="6">
                                    <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="{x:Bind FriendlyName, Mode=OneTime}" />

                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock FontWeight="SemiBold" Text="Windows name" />
                                        <TextBlock
                                            Grid.Column="1"
                                            FontFamily="Consolas"
                                            Text="{x:Bind GdiDeviceName, Mode=OneTime}" />
                                    </Grid>

                                    <TextBlock FontWeight="SemiBold" Text="Stable device path" />
                                    <TextBox
                                        Padding="0"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        FontFamily="Consolas"
                                        IsHitTestVisible="False"
                                        IsReadOnly="True"
                                        IsTabStop="False"
                                        Text="{x:Bind DevicePath, Mode=OneTime}"
                                        TextWrapping="Wrap" />

                                    <TextBlock
                                        Margin="0,6,0,0"
                                        FontWeight="SemiBold"
                                        Text="{x:Bind DdcStatus, Mode=OneTime}" />
                                    <TextBlock
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="{x:Bind DdcDetails, Mode=OneTime}"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <StackPanel
                    x:Name="EmptyState"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="8"
                    Visibility="Collapsed">
                    <FontIcon
                        HorizontalAlignment="Center"
                        FontSize="36"
                        Glyph="&#xE7F4;" />
                    <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="No active display paths were returned." />
                    <TextBlock
                        HorizontalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="Try rescanning after the Windows desktop has finished loading." />
                </StackPanel>
            </Grid>

            <!-- Configuration & Control Side Panel (Right Column) -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="12">
                    <!-- Theme Card -->
                    <Border
                        Padding="16,12"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Spacing="3">
                                <TextBlock FontWeight="SemiBold" Text="Windows theme" />
                                <TextBlock
                                    x:Name="ThemeStatusText"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="Reading current app and system theme..." />
                            </StackPanel>

                            <StackPanel
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                Orientation="Horizontal"
                                Spacing="8">
                                <Button
                                    x:Name="RefreshThemeButton"
                                    Click="RefreshThemeButton_Click"
                                    Content="Refresh" />
                                <Button
                                    x:Name="ApplyLightThemeButton"
                                    Click="ApplyLightThemeButton_Click"
                                    Content="Light" />
                                <Button
                                    x:Name="ApplyDarkThemeButton"
                                    Click="ApplyDarkThemeButton_Click"
                                    Content="Dark" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Theme Schedule Card -->
                    <Border
                        Padding="16,12"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <StackPanel Spacing="10">
                            <StackPanel Spacing="3">
                                <TextBlock FontWeight="SemiBold" Text="Custom theme schedule preview" />
                                <TextBlock
                                    x:Name="ScheduleStatusText"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="Choose different light and dark transition times."
                                    TextWrapping="Wrap" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Viewbox Width="220" Stretch="Uniform">
                                    <TimePicker
                                        x:Name="LightScheduleTimePicker"
                                        ClockIdentifier="24HourClock"
                                        Header="Light starts" />
                                 </Viewbox>

                                <Viewbox Width="220" Height="80" Stretch="Uniform">
                                    <TimePicker
                                        x:Name="DarkScheduleTimePicker"
                                        ClockIdentifier="24HourClock"
                                        Header="Dark starts" />
                                 </Viewbox>
                            </StackPanel>

                            <ToggleSwitch
                                x:Name="ScheduleAutomationToggle"
                                Header="Automatic switching"
                                OffContent="Off"
                                OnContent="On while DisplayPilot is running" />

                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Button Click="PreviewScheduleButton_Click" Content="Preview schedule" />
                                <Button Click="SaveScheduleButton_Click" Content="Save schedule" />
                            </StackPanel>

                            <TextBlock
                                x:Name="SchedulePersistenceStatusText"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="Schedule settings have not been loaded."
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <!-- Verification InfoBar -->
                    <InfoBar
                        IsClosable="False"
                        IsOpen="True"
                        Message="Read brightness first, select one validated display, then explicitly set 0–100%. DisplayPilot writes only brightness and immediately reads it back for verification."
                        Severity="Warning"
                        Title="Brightness write verification" />

                    <!-- Brightness Control -->
                    <Grid HorizontalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Brightness Control (Left) -->
                        <NumberBox
                            x:Name="BrightnessValue"
                            Grid.Column="0"
                            Width="160"
                            Header="Brightness %"
                            Maximum="100"
                            Minimum="0"
                            SmallChange="1"
                            SpinButtonPlacementMode="Inline"
                            Value="50"
                            HorizontalAlignment="Left" />

                        <!-- Button (Right) -->
                        <Button
                            x:Name="SetBrightnessButton"
                            Grid.Column="1"
                            VerticalAlignment="Bottom"
                            HorizontalAlignment="Right"
                            Click="SetBrightnessButton_Click"
                            Content="Set selected"
                            IsEnabled="False" />            
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Footer Bar -->
        <Border
            Grid.Row="2"
            Padding="24,12,24,20"
            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="3">
                    <TextBlock
                        x:Name="StatusText"
                        FontWeight="SemiBold"
                        Text="Waiting to scan..." />
                    <TextBlock x:Name="SystemText" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>

                <StackPanel
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="8">
                    <Button
                        x:Name="CopyReportButton"
                        VerticalAlignment="Bottom"
                        Click="CopyReportButton_Click"
                        Content="Copy diagnostic report"
                        IsEnabled="False" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>